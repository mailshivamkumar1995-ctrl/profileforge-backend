# ============================================================
# ProfileForge Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================================

# Django
DJANGO_ENV=development
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-STRING
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/profileforge_dev

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage backend: s3 | gcs | minio | local
STORAGE_BACKEND=minio

# MinIO (local dev)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=profileforge-dev
MINIO_USE_SSL=False

# AWS S3 (production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# AWS_S3_REGION=us-east-1

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AI Provider: openai | anthropic | gemini
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@profileforge.io

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting (requests per minute)
RATE_LIMIT_ANON=60
RATE_LIMIT_USER=300
RATE_LIMIT_AI=20

# Monitoring
SENTRY_DSN=
PROMETHEUS_METRICS_ENABLED=True
